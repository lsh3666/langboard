# Project
PROJECT_NAME=langboard
PROJECT_SHORT_NAME=lb

# Admin
ADMIN_EMAIL=admin@langboard.io
ADMIN_PASSWORD=admin
FULL_ADMIN_ACCESS_EMAILS=admin@langboard.io

# Nginx
NGINX_UI_EXPOSE_PORT=1000
NGINX_SOCKET_EXPOSE_PORT=1001
NGINX_API_EXPOSE_PORT=1002
DOCS_EXPOSE_PORT=1003

# Redis (This will be used for docker-compose)
REDIS_PORT=6379
REDIS_PASSWORD=redis
REDIS_LOG_DIR=data
REDIS_LOG_FILE=redis.log

# Cache (This will be used for local development)
# in-memory, redis
CACHE_TYPE=in-memory
CACHE_URL=

# Broadcast
# in-memory, kafka
BROADCAST_TYPE=in-memory
BROADCAST_URLS=

# Backend
API_PORT=5381
# Local api will ignore this value
API_WORKERS_COUNT=4
SOCKET_PORT=5690
FLOWS_PORT=5019
FLOWS_WORKERS_COUNT=4
# MB size
MAX_FILE_SIZE_MB=50
# Seconds (eg: 120 = 2 * 60 = 2 minutes)
AI_REQUEST_TIMEOUT=120
AI_REQUEST_TRIALS=5

# Logging
# CRITICAL, FATAL, ERROR, WARNING(WARN), INFO, DEBUG, AUTO
TERMINAL_LOGGING_LEVEL=
FILE_LOGGING_LEVEL=
LOGGING_DIR=
SOCKET_LOGGING_DIR=

# Sentry
SENTRY_DSN=

# Storage
LOCAL_STORAGE_DIR=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION_NAME=
S3_BUCKET_NAME=

# SMTP
MAIL_FROM=
MAIL_FROM_NAME=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SERVER=
MAIL_PORT=
# true, false
MAIL_STARTTLS=
# true, false
MAIL_SSL_TLS=

# Common Security
COMMON_SECRET_KEY=langboard-secret-key
JWT_SECRET_KEY=langboard-secret-key
JWT_ALGORITHM=HS256
# Access Token expiration, seconds (eg: 10800 = 60 * 60 * 3 = 3 hours)
JWT_AT_EXPIRATION=10800
# Refresh Token expiration, days (eg: 30 = 30 days)
JWT_RT_EXPIRATION=30

# Scheduler
CRON_TAB_FILE=

# UI
UI_PORT=5173
SOCKET_URL=
API_URL=
PUBLIC_UI_URL=
DOMAIN=

# DB settings
DB_TIMEOUT=120
# Only for postgres
DB_TCP_USER_TIMEOUT=1000

# Postgres external
POSTGRES_EXTERNAL_MAIN_URL=
POSTGRES_EXTERNAL_REPLICA_URL=
DB_BACKUP_UPLOAD_URL=
# Use '|' as separator for multiple headers.
# Example: Authorization: Bearer token|X-Api-Key: your-key
DB_BACKUP_UPLOAD_HEADERS=

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_REPLICATION_USER=postgres
POSTGRES_REPLICATION_PASSWORD=postgres
POSTGRES_DB=langboard
MASTER_POSTGRES_PORT=5432
REPLICA_POSTGRES_PORT=5433
POSTGRES_MAX_CONNECTIONS=100
PGBOUNCER_SERVER_IDLE_TIMEOUT=600
PGBOUNCER_CLIENT_IDLE_TIMEOUT=0
PGBOUNCER_DEFAULT_POOL_SIZE=20
PGBOUNCER_RESERVE_POOL_TIMEOUT=5
PGBOUNCER_QUERY_WAIT_TIMEOUT=120

# Kafka
# Example: e7f3c010-41c3-4a5a-bdf3-1f12b3cfb8a6
KAFKA_CLUSTER_ID=e7f3c010-41c3-4a5a-bdf3-1f12b3cfb8a6

# Ollama
# If you use Ollama in local, you can set the URL below
OLLAMA_API_URL=
OLLAMA_KEEP_ALIVE=30m

# Key Provider settings
# openbao-local, openbao-external, hashicorp, aws, azure
# - openbao-local: Uses local OpenBao container (requires .vault-credentials file)
# - openbao-external: Uses external OpenBao server (requires .vault-credentials file)
# - hashicorp: Uses external HashiCorp Vault server (requires .vault-credentials file)
# - aws: Uses AWS KMS
# - azure: Uses Azure Key Vault
KEY_PROVIDER_TYPE=openbao-local

# OpenBao (for openbao-local and openbao-external)
KEY_PROVIDER_OPENBAO_URL=http://localhost:8200
KEY_PROVIDER_OPENBAO_ROOT_TOKEN=

# HashiCorp Vault
KEY_PROVIDER_HASHICORP_URL=
KEY_PROVIDER_HASHICORP_ROLE_ID=
KEY_PROVIDER_HASHICORP_SECRET_ID=

# AWS KMS
KEY_PROVIDER_AWS_REGION=
KEY_PROVIDER_AWS_ACCESS_KEY_ID=
KEY_PROVIDER_AWS_SECRET_ACCESS_KEY=
KEY_PROVIDER_AWS_KMS_KEY_ARN=

# Azure Key Vault
KEY_PROVIDER_AZURE_KEYVAULT_URL=
KEY_PROVIDER_AZURE_CLIENT_ID=
KEY_PROVIDER_AZURE_CLIENT_SECRET=
KEY_PROVIDER_AZURE_TENANT_ID=
KEY_PROVIDER_AZURE_ENCRYPTION_KEY_NAME=
